# bin/
# build/
# develop-eggs/
# dist/
# downloads/
# eggs/
# .eggs/
# lib/
# lib64/
# parts/
# sdist/
# var/
# wheels/
# share/python-wheels/
# *.egg-info/
# .installed.cfg
# *.egg

# # Virtual Environments
# .venv/
# venv/
# ENV/
# env/
# pyenv/

# ==========================================
# 📓 JUPYTER NOTEBOOK WORKFLOWS
# ==========================================
.ipynb_checkpoints
*/.ipynb_checkpoints/

