# ==========================================
# 📊 AIRPORT INCIDENT DETECTION DATA LAYOUT
# ==========================================
# Never commit raw, intermediate, or processed large media datasets
data/raw/
data/processed/
data/sample_videos

# Ignore local video sample clips used for pipeline validation/visualizers
*.mp4
*.avi
*.mkv

# ==========================================
# 🧠 DEEP LEARNING FRAMEWORK MACHINE LEARNING
# ==========================================
# Exclude model weights checkpoints and exported artifacts (.pt, .pth, .onnx)
*.pt
*.pth
*.onnx
models/*.pt
runs/
.pytest_cache/

# ==========================================
# 🐍 PYTHON CORE ENVIRONMENT & DEPENDENCIES
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
# *.py[cod]
# *$py.class

# # C extensions
# *.so

